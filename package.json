{
  "name": "ccxl",
  "version": "3.1.1",
  "description": "ccxl (Claude Code XL) — Full-stack AI coding assistant configurator. Generate complete Claude Code, Cursor, Copilot, and Windsurf configs from a single scan.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ccxl": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "fullscreen-ink": "^0.1.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "eslint": "^9.5.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "cursor",
    "copilot",
    "windsurf",
    "ai",
    "cli",
    "config",
    "setup",
    "skills",
    "hooks",
    "agents",
    "mcp",
    "configurator"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsCodejac/ccxl.git"
  },
  "bugs": {
    "url": "https://github.com/ItsCodejac/ccxl/issues"
  },
  "homepage": "https://github.com/ItsCodejac/ccxl#readme",
  "author": "ItsCojac",
  "license": "MIT"
}
